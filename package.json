{
  "name": "aigc-study-project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @aigc-study-project/db db:push",
    "db:studio": "turbo -F @aigc-study-project/db db:studio",
    "db:generate": "turbo -F @aigc-study-project/db db:generate",
    "db:migrate": "turbo -F @aigc-study-project/db db:migrate",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@aigc-study-project/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aigc-study-project/config": "workspace:*",
    "@biomejs/biome": "^2.4.16",
    "@types/node": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
